# Production environment template for Vercel + Pollinations developer earnings.
# NEXT_PUBLIC_POLLINATIONS_APP_KEY is a publishable client id used to attribute
# every API call back to the Thumbshare app for developer earnings. It is NOT a
# spend key; real user BYOP keys are provided by the user at runtime.
#
# Copy this file to the Vercel project env (or set the variables directly in
# the Vercel dashboard) so that `next build` inlines the app key into the JS
# bundle and Pollinations attributes traffic to this app id.
NEXT_PUBLIC_POLLINATIONS_APP_KEY=pk_4vwdCAbLf8wWIOJE
POLLINATIONS_TEXT_MODEL=openai
POLLINATIONS_ALLOW_MOCK=false
