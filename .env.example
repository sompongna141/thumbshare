# Publishable app key used as Pollinations BYOP client_id / app identifier
# This is NOT a spend key.
NEXT_PUBLIC_POLLINATIONS_APP_KEY=pk_4vwdCAbLf8wWIOJE

# Deployed origin used to build the OAuth redirect_uri at SSR time.
# Must match exactly one of the redirect URIs registered for the app
# key at enter.pollinations.ai (no trailing slash, no path beyond /studio).
NEXT_PUBLIC_SITE_ORIGIN=https://thumbsnare.vercel.app

# Text model for generation
POLLINATIONS_TEXT_MODEL=openai

# Development mock fallback (must be "false" in production)
POLLINATIONS_ALLOW_MOCK=false
